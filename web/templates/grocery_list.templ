package templates

templ GroceryListStandalone(items []GroceryItemData, unitSystem string) {
	@Layout("Grocery List") {
		<h1>Grocery List</h1>
		<table class="ingredients-table ingredients-table-standalone">
			<colgroup>
				<col class="ingredient-col-qty"/>
				<col class="ingredient-col-unit"/>
				<col class="ingredient-col-name"/>
			</colgroup>
			<tbody>
				for _, item := range items {
					<tr>
						if unitSystem == "us" && item.UnitUS != "" {
							<td class="ingredient-qty">{ formatQuantity(item.QuantityUS) }</td>
							<td class="ingredient-unit">
								if !shouldHideUnit(item.QuantityUS, item.UnitUS) {
									{ item.UnitUS }
								}
							</td>
						} else {
							<td class="ingredient-qty">{ formatQuantity(item.TotalQuantity) }</td>
							<td class="ingredient-unit">
								if !shouldHideUnit(item.TotalQuantity, item.Unit) {
									{ item.Unit }
								}
							</td>
						}
						<td class="ingredient-name">{ item.Name }</td>
					</tr>
				}
			</tbody>
		</table>
	}
}
